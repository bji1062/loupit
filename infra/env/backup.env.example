# infra/env/backup.env.example — SP-INFRA-10.2 백업 크레덴셜 템플릿(커밋 대상, 비밀 플레이스홀더).
# 실 배포: infra/env/backup.env 로 복사 후 값 채움(chmod 600, ubuntu 소유). backup.env는 gitignore로 미커밋.
# loupit-backup.service(EnvironmentFile)와 restore.sh가 이 파일을 읽는다.
#
# ── 실환경 주의(감사 2026-07-17) ──
#  · DB_NAME 은 대문자 LOUPIT(서빙 스키마, lower_case_table_names=0) — 소문자 loupit는 별개 DB.
#  · 그랜트가 '@127.0.0.1' 한정 → backup.sh/restore.sh가 --protocol=TCP 로 접속(소켓 접속은 Access denied).
#  · 실계정은 APP_LOUPIT(ALL ON LOUPIT.*). mysqldump는 --no-tablespaces 로 PROCESS 권한 없이 동작.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=APP_LOUPIT
DB_PASSWORD=<BACKUP_DB_PW>
DB_NAME=LOUPIT
BACKUP_DIR=/var/backups/loupit
RETENTION_DAYS=14
