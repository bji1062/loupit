# infra/env/server.env.example — SP-INFRA-7.1 템플릿(비밀 플레이스홀더, 커밋 대상).
# 실 배포 시 server/.env 로 복사(chmod 600, ubuntu 소유, gitignore) 후 값 채움.
# 인증·메일·소셜·JWT 키 정의 금지(부재 자체가 계약, NFR16): JWT_SECRET/OAUTH_*/SMTP_*/SESSION_SECRET 없음.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=loupit
DB_PASSWORD=<RUNTIME_PW>
DB_NAME=loupit
CORS_ALLOW_ORIGINS=https://loupit.co,https://www.loupit.co
REFERENCE_CACHE_TTL=3600
REFERENCE_CACHE_CONTROL=public, max-age=3600
