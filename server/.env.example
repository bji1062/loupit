# loupit server 환경변수 예시 (SP-API config).
# JWT/OAuth/SMTP 키 없음 — 인증·회원·메일 제거(INV-1·NFR16·NFR20).
# 실제 값은 server/.env 로 복사(gitignore). 서버는 읽기 전용.

# --- DB (loopback, 최소권한 읽기 전용 계정) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=loupit_ro
DB_PASSWORD=change_me
DB_NAME=loupit

# --- CORS (동일 오리진 배포 — 개발 시에만 사용, INV-7) ---
CORS_ALLOW_ORIGINS=http://localhost:8000

# --- 참조 번들 인메모리 캐시 TTL(초) — reference/all: public, max-age=3600 ---
REFERENCE_CACHE_TTL=3600
