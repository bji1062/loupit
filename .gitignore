# ─────────────────────────────────────────────
# loupit .gitignore
# ─────────────────────────────────────────────

# ── Secrets / env (절대 커밋 금지) ──
.env
.env.*
!.env.example
*.pem
*.key
secrets.*
server/.env

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.Python
venv/
.venv/
env/
# infra/env/ 는 파이썬 venv가 아니라 SP-INFRA-2.4 정본 산출 디렉토리(server.env.example 템플릿) —
# 위 범용 `env/` 규칙에서 명시적으로 예외 처리한다(디렉토리 자체 + 내용물 둘 다 un-ignore 필요).
!infra/env/
!infra/env/**
# 단, 실비밀(infra/env/*.env: server.env·backup.env 등)은 다시 무시하고 *.env.example 템플릿만 커밋한다.
# (*.env.example 은 .env 로 끝나지 않아 아래 규칙에 걸리지 않는다. 순서상 위 un-ignore 뒤에 와야 유효.)
infra/env/*.env
!infra/env/*.env.example
server/venv/
server/.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# ── Node / 프론트 툴링 (필요시) ──
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── 빌드 산출물 (빌드타임 생성물) ──
*.gz
# 정적 생성 회사/조합 페이지 출력 디렉토리 (빌드 결과 — 소스에서 재생성)
dist-static/
public/generated/
sitemap.xml
robots.txt.generated

# ── 광고/제휴 비공개 키 (있다면) ──
ads.local.*

# ── 인프라 (Terraform) ──
*.tfstate
*.tfstate.*
.terraform/
*.tfvars
!*.tfvars.example
crash.log

# ── OMC / Claude 로컬 상태 ──
.omc/
.claude/settings.local.json
.playwright-mcp/

# ── OS / 에디터 ──
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/
*.bak
*.tmp
web/dist.prev/
.gstack/
